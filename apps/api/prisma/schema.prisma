datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TaskStatus {
  queued
  running
  done
  failed
}

enum AgentType {
  feature
  bugfix
  support
  improve
}

model Task {
  id        String     @id @default(cuid())
  issueKey  String
  title     String
  repo      Repo       @relation(fields: [repoId], references: [id])
  repoId    String
  agentType AgentType
  status    TaskStatus @default(queued)
  round     Int        @default(0)
  maxRounds Int        @default(5)
  log       String     @default("")
  mrUrl     String?
  error     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([repoId])
}

model Repo {
  id          String   @id @default(cuid())
  name        String   @unique
  path        String
  githubRepo  String
  description String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  tasks       Task[]
}

model Setting {
  key   String @id
  value String
}
