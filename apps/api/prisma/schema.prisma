datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum TaskStatus {
  queued
  running
  done
  failed
}

enum AgentType {
  feature
  bugfix
  support
  improve
}

enum TaskProgressPhase {
  jira_fetch
  queued
  preflight
  understand
  plan
  code
  verify
  pr
  complete
}

enum TaskProgressStatus {
  started
  completed
  failed
  skipped
  looped
}

model Task {
  id             String              @id @default(cuid())
  issueKey       String
  title          String
  repo           Repo                @relation(fields: [repoId], references: [id])
  repoId         String
  agentType      AgentType
  status         TaskStatus          @default(queued)
  round          Int                 @default(0)
  maxRounds      Int                 @default(5)
  log            String              @default("")
  mrUrl          String?
  error          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  progressEvents TaskProgressEvent[]

  @@index([status])
  @@index([repoId])
}

model TaskProgressEvent {
  id        String             @id @default(cuid())
  task      Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  round     Int                @default(0)
  phase     TaskProgressPhase
  status    TaskProgressStatus
  message   String             @default("")
  createdAt DateTime           @default(now())

  @@index([taskId, round, createdAt])
}

model Repo {
  id          String   @id @default(cuid())
  name        String   @unique
  path        String
  githubRepo  String?
  description String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  tasks       Task[]
}

model Setting {
  key   String @id
  value String
}
